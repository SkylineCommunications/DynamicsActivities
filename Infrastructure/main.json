            "value": "[parameters('corsOrigins')]"
          },
          "instantCooldownMinutes": {
            "value": "[parameters('instantCooldownMinutes')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.36.177.2456",
              "templateHash": "4905314661182807801"
            }
          },
          "parameters": {
            "appName": {
              "type": "string"
            },
            "appServicePlanId": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "environment": {
              "type": "string"
            },
            "storageConnectionString": {
              "type": "string"
            },
            "appInsightsConnectionString": {
              "type": "string"
            },
            "dataverseUrl": {
              "type": "string"
            },
            "dataverseClientId": {
              "type": "string"
            },
            "dataverseClientSecret": {
              "type": "securestring"
            },
            "sendGridApiKey": {
              "type": "securestring"
            },
            "openaiApiKey": {
              "type": "securestring"
            },
            "entraIdTenantId": {
              "type": "string"
            },
            "functionClientId": {
              "type": "string"
            },
            "corsOrigins": {
              "type": "string"
            },
            "instantCooldownMinutes": {
              "type": "int",
              "defaultValue": 15
            }
          },
          "resources": [
