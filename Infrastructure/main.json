          "storageConnectionString": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'storage-deployment'), '2022-09-01').outputs.connectionString.value]"
          },
          "appInsightsConnectionString": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appinsights-deployment'), '2022-09-01').outputs.connectionString.value]"
          },
          "dataverseUrl": {
            "value": "[parameters('dataverseUrl')]"
          },
          "dataverseClientId": {
            "value": "[parameters('dataverseClientId')]"
          },
          "dataverseClientSecret": {
            "value": "[parameters('dataverseClientSecret')]"
          },
          "sendGridApiKey": {
            "value": "[parameters('sendGridApiKey')]"
          },
          "openaiApiKey": {
            "value": "[parameters('openaiApiKey')]"
          },
          "entraIdTenantId": {
            "value": "[parameters('entraIdTenantId')]"
          },
          "functionClientId": {
            "value": "[parameters('functionClientId')]"
          },
